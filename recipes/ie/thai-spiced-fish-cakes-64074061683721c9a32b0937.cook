source: https://www.hellofresh.ie/recipes/thai-spiced-fish-cakes-64074061683721c9a32b0937
author: HelloFresh
servings: 2
course: main course
time required: 40m
nutrition:
  calories: 523 kcal
  fat: 23.6 g
