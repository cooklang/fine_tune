image: https://img.hellofresh.com/f_auto,fl_lossy,h_640,q_auto,w_1200/hellofresh_s3/image/HF_Y23_R23_W18_UK_V13474-5_Main_low-452b9f41.jpg
pdf: https://www.hellofresh.co.uk/recipecards/card/lentil-and-mushroom-cottage-pie-63fe37a810ddad6ab9e1497a-529d28d9.pdf
