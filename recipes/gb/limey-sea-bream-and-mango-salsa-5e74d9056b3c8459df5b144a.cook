image: https://img.hellofresh.com/f_auto,fl_lossy,h_640,q_auto,w_1200/hellofresh_s3/image/limey-sea-bream-and-mango-salsa-880eeedb-2b568895.jpg
pdf: https://www.hellofresh.co.uk/recipecards/card/limey-sea-bream-and-mango-salsa-5e74d9056b3c8459df5b144a-c4557b1f.pdf
