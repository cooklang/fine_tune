image: https://img.hellofresh.com/f_auto,fl_lossy,h_640,q_auto,w_1200/hellofresh_s3/image/HF_Y24_R07_W25_UK_UQ22110-3_switch_chicken_edit_Main_high-c1a8a9dc.jpg
