image: https://img.hellofresh.com/f_auto,fl_lossy,h_640,q_auto,w_1200/hellofresh_s3/image/sirloin-steak-and-creamy-tarragon-sauce-608db620-b9ab00b6.jpg
pdf: https://www.hellofresh.co.uk/recipecards/card/sirloin-steak-and-creamy-tarragon-sauce-6124c7975f2adc5d5e61eefa-7a4d4156.pdf
