image: https://img.hellofresh.com/f_auto,fl_lossy,h_640,q_auto,w_1200/hellofresh_s3/image/mango-chutney-glazed-spiced-chicken-breast-a1473a0b-81f75d52.jpg
pdf: https://www.hellofresh.co.uk/recipecards/card/mango-chutney-glazed-spiced-chicken-breast-5e3c2af8f54f254e52272f45-b27fa174.pdf
