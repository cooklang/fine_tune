source: https://www.hellofresh.co.uk/recipes/red-wine-glazed-lamb-shank-5f7f1e8e22e21d6c207f2d67
author: Michael Steadman
servings: 2
nutrition:
  calories: 722 kcal
  fat: 35 g
  saturated fat: 15 g
  carbohydrates: 60 g
