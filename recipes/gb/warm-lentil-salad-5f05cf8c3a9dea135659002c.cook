servings: 2
time required: 45 minutes
cuisine: Middle Eastern
author: HelloFresh
nutrition:
  calories: 632 kcal
  fat: 15 g
  saturated fat: 9 g
  carbohydrates: 93 g
  sugar: 21 g
  protein: 28 g
