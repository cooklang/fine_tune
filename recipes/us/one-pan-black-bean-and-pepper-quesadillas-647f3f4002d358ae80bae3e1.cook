source: https://www.hellofresh.com/recipes/one-pan-black-bean-and-pepper-quesadillas-647f3f4002d358ae80bae3e1
course: main course
time required: 15 minutes
servings: 2
cuisine: Mexican
nutrition:
  calories: 910 kcal
