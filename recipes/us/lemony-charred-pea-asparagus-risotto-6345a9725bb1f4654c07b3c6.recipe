nutrition:
  calories: 620 kcal
  fat: 26 g
  saturated fat: 11 g
  carbohydrates: 89 g
  sugar: 9 g
  protein: 15 g
  fiber: 8 g
  sodium: 550 mg
servings: 2
course: main course
time required: 45 minutes
cuisine: North America
