nutrition:
  calories: 930 kcal
  fat: 54 g
  saturated fat: 22 g
  carbohydrates: 76 g
  sugar: 9 g
  protein: 37 g
  fiber: 5 g
  sodium: 940 mg
course: main course
author: Michelle Doll Olson
servings: 2
time required: 30 minutes
cuisine: Mexican
