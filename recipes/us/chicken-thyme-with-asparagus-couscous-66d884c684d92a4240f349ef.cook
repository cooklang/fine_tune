source: https://www.hellofresh.com/recipes/chicken-thyme-with-asparagus-couscous-66d884c684d92a4240f349ef
author: HelloFresh
servings: 2
time required: 35 minutes
cuisine: Southern Europe
nutrition:
  calories: 550 kcal
