cuisine: Mexican
source: https://www.hellofresh.com/recipes/southwest-turkey-cauliflower-rice-615dbaac78c5104dd5312bed
servings: 2
author: HelloFresh
nutrition:
  calories: 580 kcal
  fat: 38 g
