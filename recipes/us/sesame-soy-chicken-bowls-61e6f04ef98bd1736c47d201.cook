course: main course
author: HelloFresh
servings: 2
source: https://www.hellofresh.com/recipes/sesame-soy-chicken-bowls-61e6f04ef98bd1736c47d201
time required: 20 minutes
cuisine: Thai
nutrition:
  calories: 950 kcal
