nutrition:
  calories: 850 kcal
  fat: 53 g
  saturated fat: 15 g
  carbohydrates: 63 g
  sugar: 15 g
  protein: 21 g
  fiber: 7 g
  sodium: 1310 mg
servings: 2
time required: 30 minutes
