source: https://www.hellofresh.com/recipes/banh-mi-meatball-bowls-6006fe3bfa868674aa3c47b9
time required: 30 minutes
cuisine: Asian
author: Michelle Doll Olson
nutrition:
  calories: 830 kcal
  fat: 42 g
