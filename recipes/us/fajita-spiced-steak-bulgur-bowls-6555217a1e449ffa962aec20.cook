  fiber: 9 g
  sodium: 560 mg
servings: 2
course: main course
cuisine: Latin
author: HelloFresh
source: https://www.hellofresh.com/recipes/fajita-spiced-steak-bulgur-bowls-6555217a1e449ffa962aec20
time required: 30 minutes
