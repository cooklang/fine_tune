cuisine: Mexican
time required: 35 minutes
nutrition:
  calories: 800 kcal
  fat: 45 g
  saturated fat: 20 g
  carbohydrates: 65 g
  sugar: 9 g
  protein: 34 g
  fiber: 4 g
  sodium: 1120 mg
servings: 2
author: Michelle Doll Olson
course: main course
