cuisine: North America
source: https://www.hellofresh.com/recipes/shrimp-and-charred-corn-burrito-bowls-65cd0ac0cc89468059ab073b
author: HelloFresh
servings: 2
time required: 20 minutes
nutrition:
  calories: 660 kcal
  fat: 20 g
