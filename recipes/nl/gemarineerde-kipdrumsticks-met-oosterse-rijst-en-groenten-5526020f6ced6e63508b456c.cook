  calories: 804 kcal
  fat: 32 g
  saturated fat: 12 g
  carbohydrates: 77 g
  protein: 47 g
  fiber: 11 g
servings: 2
course: Hoofdgerecht
time required: 45 minutes
cuisine: Aziatisch
