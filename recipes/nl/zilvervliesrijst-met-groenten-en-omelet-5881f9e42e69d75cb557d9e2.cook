nutrition:
  calories: 670 kcal
  fat: 34 g
  saturated fat: 7.4 g
  carbohydrates: 65 g
  sugar: 8 g
  protein: 21 g
  fiber: 10 g
  sodium: 0.3 g
  serving size: 596
