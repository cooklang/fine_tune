source: https://www.hellofresh.ch/recipes/fruhsommerliche-cremesuppe-mit-spargel-5cd42834d5c2f8000b496435
nutrition:
  calories: 915 kcal
  fat: 61 g
  saturated fat: 22 g
  carbohydrates: 61 g
